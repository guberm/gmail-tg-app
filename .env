# Replace with your actual Google OAuth Client ID
# Instructions:
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a new Project (or select an existing one)
# 3. Go to "APIs & Services" -> "OAuth consent screen" and configure it (you can set it to External, add the "Gmail API" scopes)
# 4. Go to "Credentials" -> "Create credentials" -> "OAuth client ID"
# 5. Application type: Web application
# 6. Authorized JavaScript origins: http://localhost:5173
# 7. Authorized redirect URIs: http://localhost:5173
# 8. Copy the generated Client ID and paste it below:

VITE_GOOGLE_CLIENT_ID="601432802105-ae1rctm9hjb59nfu6m00lrcrijqcllmh.apps.googleusercontent.com"
